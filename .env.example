# Telegram
BOT_TOKEN=

# ProxyAPI: один ключ для LLM и Whisper, если LLM_PROVIDER/TRANSCRIPTION_PROVIDER=proxyapi
PROXYAPI_API_KEY=

# Запасные провайдеры (не обязательны при proxyapi)
MASHAGPT_API_KEY=
BOTHUB_API_KEY=

LLM_PROVIDER=proxyapi
LLM_MODEL=anthropic/claude-sonnet-4-5
LLM_BASE_URL=https://openai.api.proxyapi.ru/v1

TRANSCRIPTION_PROVIDER=proxyapi
TRANSCRIPTION_MODEL=whisper-1

# Google Sheets: service account + шаблоны (копии листов и /create_sheets)
GOOGLE_SERVICE_ACCOUNT_FILE=./koc8-bot-d806c14ea1fa.json
BIO_TEMPLATE_ID=
MONEY_TEMPLATE_ID=
DEFAULT_BIO_SHEET_ID=
DEFAULT_MONEY_SHEET_ID=

DATABASE_PATH=./data/bot.sqlite3
TIMEZONE=Europe/Minsk
MAX_VOICE_SECONDS=120
REPORT_HOUR=9
REPORT_MINUTE=0
ENABLE_WEEKLY_REPORTS=true
ENABLE_MONTHLY_REPORTS=true
DELETE_WEBHOOK_ON_START=true
LOG_LEVEL=INFO
